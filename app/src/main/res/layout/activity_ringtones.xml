<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ringtones"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Custom ringtones you add are private to your account — no one else can see or use them."
        android:textSize="12.5sp"
        android:textColor="#888888"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/addRingtoneButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="+ Add your own"
        android:layout_marginBottom="16dp" />

    <ListView
        android:id="@+id/ringtoneList"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</LinearLayout>
