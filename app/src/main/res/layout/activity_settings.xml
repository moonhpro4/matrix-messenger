<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Settings"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp" />

    <TextView
        android:id="@+id/accountRow"
        style="@style/SettingsRow"
        android:text="Account" />

    <TextView
        android:id="@+id/languageRow"
        style="@style/SettingsRow"
        android:text="Language" />

    <TextView
        android:id="@+id/backupsRow"
        style="@style/SettingsRow"
        android:text="Backups" />

    <TextView
        android:id="@+id/ringtonesRow"
        style="@style/SettingsRow"
        android:text="Ringtones" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#DDDDDD"
        android:layout_marginVertical="12dp" />

    <TextView
        android:id="@+id/reportMatrixRow"
        style="@style/SettingsRow"
        android:text="Report Matrix"
        android:textColor="#CC0000" />

</LinearLayout>
